<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Test buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_test_start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ Test Start"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_test_stop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="■ Test Stop"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_recording_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Idle — waiting for trigger"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/state_idle"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UDP: "
                    android:textSize="13sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/tv_udp_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="starting…"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone IP: "
                    android:textSize="13sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/tv_phone_ip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="—"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_refresh_phone_ip"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="↺"
                    android:textSize="16sp"
                    android:padding="0dp"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PC: "
                    android:textSize="13sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/tv_pc_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="not configured"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Audio input card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AUDIO INPUT"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <Spinner
                    android:id="@+id/spinner_mic"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btn_refresh_mics"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="↺"
                    android:textSize="16sp"
                    android:padding="0dp"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sample rate:"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <Spinner
                    android:id="@+id/spinner_sample_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- Last file card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LAST RECORDED"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_last_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tv_transfer_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Event log card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EVENT LOG"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="3dp"
                android:textColor="#333333" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
