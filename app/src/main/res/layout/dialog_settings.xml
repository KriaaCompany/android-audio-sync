<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PC IP Address"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/et_pc_ip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 192.168.1.100"
        android:inputType="textNoSuggestions"
        android:maxLines="1"
        android:layout_marginBottom="14dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload Port (HTTP receiver on PC)"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/et_upload_port"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="9878"
        android:inputType="number"
        android:maxLines="1"
        android:layout_marginBottom="14dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="UDP Listen Port (trigger from PC)"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="2dp" />

    <EditText
        android:id="@+id/et_udp_port"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="9877"
        android:inputType="number"
        android:maxLines="1" />

</LinearLayout>
